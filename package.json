{
	"name": "saas-boilerplate",
	"version": "0.1.0",
	"private": true,
	"packageManager": "bun@1.3.11",
	"description": "A production-minded SaaS boilerplate for Next.js on Cloudflare Workers.",
	"license": "MIT",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/SH20RAJ/saas-boilerplate.git"
	},
	"bugs": {
		"url": "https://github.com/SH20RAJ/saas-boilerplate/issues"
	},
	"homepage": "https://github.com/SH20RAJ/saas-boilerplate#readme",
	"keywords": [
		"nextjs",
		"cloudflare-workers",
		"opennext",
		"bun",
		"saas",
		"stack-auth",
		"dodo-payments",
		"drizzle",
		"d1"
	],
	"engines": {
		"node": ">=22.0.0",
		"bun": ">=1.3.0"
	},
	"scripts": {
		"dev": "next dev",
		"build": "next build",
		"preview": "opennextjs-cloudflare build && opennextjs-cloudflare preview",
		"deploy": "opennextjs-cloudflare build && opennextjs-cloudflare deploy",
		"upload": "opennextjs-cloudflare build && opennextjs-cloudflare upload",
		"cf-typegen": "wrangler types --env-interface CloudflareEnv ./cloudflare-env.d.ts",
		"lint": "biome check .",
		"format": "biome format --write .",
		"format:check": "biome format .",
		"typecheck": "tsc --noEmit",
		"test": "vitest run --passWithNoTests",
		"test:e2e": "playwright test",
		"validate": "bun run format && bun run lint && bun run typecheck && bun run test"
	},
	"dependencies": {
		"@opennextjs/cloudflare": "^1.19.9",
		"clsx": "^2.1.1",
		"next": "16.2.6",
		"react": "^19.1.7",
		"react-dom": "^19.1.7",
		"tailwind-merge": "^3.6.0"
	},
	"devDependencies": {
		"@biomejs/biome": "^2.3.8",
		"@eslint/eslintrc": "^3",
		"@playwright/test": "^1.57.0",
		"@tailwindcss/postcss": "^4",
		"@types/node": "^25.9.1",
		"@types/react": "^19.1.7",
		"@types/react-dom": "^19.1.7",
		"eslint": "^9",
		"eslint-config-next": "16.2.6",
		"tailwindcss": "^4",
		"typescript": "^5.7.4",
		"vitest": "^4.0.14",
		"wrangler": "^4.94.0"
	}
}
